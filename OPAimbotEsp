local function isSameTeam(player)
    if not Config.TeamCheck then return false end
    if player.Team == LocalPlayer.Team then return true end
    return false
end

local function getClosestToMouse()
    local closest, minDistance = nil, math.huge
    local mousePos = UserInputService:GetMouseLocation()

    for _, player in pairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and not isSameTeam(player) then
            local char = player.Character
            if char and char:FindFirstChild("Head") and char:FindFirstChild("Humanoid") and char.Humanoid.Health > 0 then
                local pos, onScreen = Camera:WorldToViewportPoint(char.Head.Position)
                if onScreen then
                    local dist = (Vector2.new(pos.X, pos.Y) - mousePos).Magnitude
                    if dist < minDistance then
                        minDistance = dist
                        closest = char.Head
                    end
                end
            end
        end
    end
    return closest
end

local ESP_Cache = {}

local function createDrawing(type)
    local obj = Drawing.new(type)
    obj.Visible = false
    if type == "Line" then obj.Thickness = 1.5 end
    if type == "Square" then obj.Thickness = 1.5; obj.Filled = false end
    return obj
end

local function setupESP(player)
    if ESP_Cache[player] then return end
    ESP_Cache[player] = {
        Box = createDrawing("Square"),
        HealthBarBG = createDrawing("Line"),
        HealthBar = createDrawing("Line"),
        Tracer = createDrawing("Line"),
        Bones = {
            createDrawing("Line"), createDrawing("Line"), createDrawing("Line"),
            createDrawing("Line"), createDrawing("Line"), createDrawing("Line")
        },
        Cham = nil
    }
    
    ESP_Cache[player].Box.Color = Color3.fromRGB(255, 255, 255)
    ESP_Cache[player].HealthBarBG.Color = Color3.fromRGB(0, 0, 0)
    ESP_Cache[player].HealthBarBG.Thickness = 3
    ESP_Cache[player].HealthBar.Color = Color3.fromRGB(0, 255, 0)
    ESP_Cache[player].Tracer.Color = Color3.fromRGB(255, 60, 60)
    for _, bone in pairs(ESP_Cache[player].Bones) do bone.Color = Color3.fromRGB(255, 255, 255) end
end

local function removeESP(player)
    if ESP_Cache[player] then
        ESP_Cache[player].Box:Remove()
        ESP_Cache[player].HealthBarBG:Remove()
        ESP_Cache[player].HealthBar:Remove()
        ESP_Cache[player].Tracer:Remove()
        for _, bone in pairs(ESP_Cache[player].Bones) do bone:Remove() end
        if ESP_Cache[player].Cham then ESP_Cache[player].Cham:Destroy() end
        ESP_Cache[player] = nil
    end
end

Players.PlayerAdded:Connect(setupESP)
Players.PlayerRemoving:Connect(removeESP)
for _, p in pairs(Players:GetPlayers()) do
    if p ~= LocalPlayer then
        setupESP(p)
    end
end

RunService:BindToRenderStep("MinimalCombatLoop", Enum.RenderPriority.Camera.Value + 1, function()
    if Config.AimbotEnabled and isAiming then
        AimbotTarget = getClosestToMouse()
        if AimbotTarget then
            Camera.CFrame = CFrame.new(Camera.CFrame.Position, AimbotTarget.Position)
        end
    else
        AimbotTarget = nil
    end

    for player, esp in pairs(ESP_Cache) do
        local char = player.Character
        local hum = char and char:FindFirstChild("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        
        if char and hum and hum.Health > 0 and hrp and not isSameTeam(player) then
            local rootPos, onScreen = Camera:WorldToViewportPoint(hrp.Position)
            local headPos = Camera:WorldToViewportPoint(char:FindFirstChild("Head") and char.Head.Position + Vector3.new(0, 0.5, 0) or hrp.Position)
            local legPos = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            if onScreen then
                local boxHeight = math.abs(headPos.Y - legPos.Y)
                local boxWidth = boxHeight / 2
                local boxPosition = Vector2.new(rootPos.X - boxWidth / 2, headPos.Y)

                if Config.ESP_Box then
                    esp.Box.Size = Vector2.new(boxWidth, boxHeight)
                    esp.Box.Position = boxPosition
                    esp.Box.Visible = true
                else
                    esp.Box.Visible = false
                end

                if Config.ESP_Health then
                    local healthPct = hum.Health / hum.MaxHealth
                    esp.HealthBarBG.From = Vector2.new(boxPosition.X - 5, boxPosition.Y + boxHeight)
                    esp.HealthBarBG.To = Vector2.new(boxPosition.X - 5, boxPosition.Y)
                    esp.HealthBarBG.Visible = true

                    esp.HealthBar.From = Vector2.new(boxPosition.X - 5, boxPosition.Y + boxHeight)
                    esp.HealthBar.To = Vector2.new(boxPosition.X - 5, boxPosition.Y + boxHeight - (boxHeight * healthPct))
                    esp.HealthBar.Color = Color3.fromRGB(255 - (healthPct * 255), healthPct * 255, 0)
                    esp.HealthBar.Visible = true
                else 
                    esp.HealthBarBG.Visible = false
                    esp.HealthBar.Visible = false 
                end

                if Config.ESP_Line then
                    esp.Tracer.From = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y)
                    esp.Tracer.To = Vector2.new(rootPos.X, legPos.Y)
                    esp.Tracer.Visible = true
                else
                    esp.Tracer.Visible = false
                end

                if Config.ESP_Skeleton then
                    local function drawBone(index, p1Name, p2Name)
                        local p1 = char:FindFirstChild(p1Name)
                        local p2 = char:FindFirstChild(p2Name)
                        if p1 and p2 then
                            local s1, o1 = Camera:WorldToViewportPoint(p1.Position)
                            local s2, o2 = Camera:WorldToViewportPoint(p2.Position)
                            if o1 and o2 then
                                esp.Bones[index].From = Vector2.new(s1.X, s1.Y)
                                esp.Bones[index].To = Vector2.new(s2.X, s2.Y)
                                esp.Bones[index].Visible = true
                                return
                            end
                        end
                        esp.Bones[index].Visible = false
                    end
                    
                    drawBone(1, "Head", "UpperTorso")
                    if not char:FindFirstChild("UpperTorso") then
                        drawBone(1, "Head", "Torso")
                    end
                    
                    local torso = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
                    if torso then
                        drawBone(2, torso.Name, char:FindFirstChild("LeftUpperArm") and "LeftUpperArm" or "Left Arm")
                        drawBone(3, torso.Name, char:FindFirstChild("RightUpperArm") and "RightUpperArm" or "Right Arm")
                        drawBone(4, torso.Name, char:FindFirstChild("LeftUpperLeg") and "LeftUpperLeg" or "Left Leg")
                        drawBone(5, torso.Name, char:FindFirstChild("RightUpperLeg") and "RightUpperLeg" or "Right Leg")
                    end
                else
                    for _, bone in pairs(esp.Bones) do
                        bone.Visible = false
                    end
                end

                if Config.ESP_Chams then
                    if not esp.Cham or esp.Cham.Parent ~= char then
                        if esp.Cham then esp.Cham:Destroy() end
                        esp.Cham = Instance.new("Highlight")
                        esp.Cham.FillTransparency = 0.5
                        esp.Cham.OutlineTransparency = 0
                        esp.Cham.FillColor = Color3.fromRGB(255, 60, 60)
                        esp.Cham.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
                        esp.Cham.Parent = char
                    end
                    esp.Cham.Enabled = true
                else
                    if esp.Cham then
                        esp.Cham.Enabled = false
                    end
                end
            else
                esp.Box.Visible = false
                esp.HealthBarBG.Visible = false
                esp.HealthBar.Visible = false
                esp.Tracer.Visible = false
                for _, bone in pairs(esp.Bones) do
                    bone.Visible = false
                end
            end
        else
            esp.Box.Visible = false
            esp.HealthBarBG.Visible = false
            esp.HealthBar.Visible = false
            esp.Tracer.Visible = false
            for _, bone in pairs(esp.Bones) do
                bone.Visible = false
            end
            if esp.Cham then
                esp.Cham.Enabled = false
            end
        end
    end
end)
